{
  "name": "sorechat-desktop",
  "version": "1.0.0",
  "description": "Sore Chat - a fast, private chat app for Windows",
  "main": "electron/main.js",
  "author": "Sore Chat",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "prestart": "npm run build:web",
    "start": "electron .",
    "build:win": "npm run build:web && electron-builder --win",
    "publish:win": "npm run build:web && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.4",
    "electron-log": "^5.1.7",
    "firebase": "^10.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1"
  },
  "build": {
    "appId": "com.sorechat.app",
    "productName": "Sore Chat",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "sorechat-desktop"
      }
    ]
  }
}
