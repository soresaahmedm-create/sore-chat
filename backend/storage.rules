rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /chats/{chatId}/{fileName} {
      allow read: if request.auth != null;
      // Free tier: 25MB cap enforced server-side too (client check can be bypassed).
      // Pro tier: raise per-user via a custom claim set by the payment webhook.
      allow write: if request.auth != null &&
        request.resource.size < 25 * 1024 * 1024;
    }
  }
}
