rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /chats/{chatId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId;
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds &&
          (
            // Reactions: any participant
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) ||
            // Edit own text
            (request.auth.uid == resource.data.senderId &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited'])) ||
            // Pin / unpin: any participant
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned']) ||
            // Star / unstar: any participant may toggle the shared array
            // (each client only ever adds/removes its own uid; a stricter
            // per-uid check isn't expressible without duplicating the
            // request array server-side, so this trusts client behavior
            // the way reactions already do)
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['starredBy']) ||
            // "Delete for me": any participant may add themself to the
            // hidden-for list
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor']) ||
            // "Delete for everyone": sender only, within 1 hour of sending —
            // this is the real enforcement point (the client-side check in
            // firebase.js is just a friendlier pre-check)
            (request.auth.uid == resource.data.senderId &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'mediaUrl', 'reactions', 'deletedForEveryone']) &&
             request.resource.data.deletedForEveryone == true &&
             request.time < resource.data.createdAt + duration.value(1, 'h'))
          );
        allow delete: if request.auth != null &&
          request.auth.uid == resource.data.senderId;
      }

      match /typing/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /calls/{callId} {
      allow read, update: if request.auth != null &&
        (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.calleeId);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.callerId;

      match /callerCandidates/{c} {
        allow read, create: if request.auth != null;
      }
      match /calleeCandidates/{c} {
        allow read, create: if request.auth != null;
      }
    }

    match /transfers/{transferId} {
      allow read, update: if request.auth != null &&
        (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.fromId;

      match /fromCandidates/{c} {
        allow read, create: if request.auth != null;
      }
      match /toCandidates/{c} {
        allow read, create: if request.auth != null;
      }
    }
  }
}
